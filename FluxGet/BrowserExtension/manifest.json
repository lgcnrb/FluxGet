{
  "manifest_version": 3,
  "name": "FluxGet",
  "version": "2.0.0",
  "description": "FluxGet Download Manager browser extension",
  "permissions": [
    "activeTab",
    "tabs",
    "contextMenus",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "http://localhost:19874/*",
    "https://www.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "context_menus": [
    {
      "id": "download-with-fluxget",
      "title": "Download with FluxGet",
      "contexts": ["link", "image", "video", "audio"]
    },
    {
      "id": "download-video-with-fluxget",
      "title": "Download video with FluxGet",
      "contexts": ["video"]
    },
    {
      "id": "download-image-with-fluxget",
      "title": "Download image with FluxGet",
      "contexts": ["image"]
    },
    {
      "id": "download-page-with-fluxget",
      "title": "Download all links on page",
      "contexts": ["page"]
    },
    {
      "id": "download-selected-with-fluxget",
      "title": "Download selection with FluxGet",
      "contexts": ["selection"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
