<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FluxGet.UI.Views.DownloadsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:FluxGet.UI.Converters"
    mc:Ignorable="d">
    
    <Page.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="32,20,32,0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <FontIcon Glyph="&#xE896;" FontSize="28" VerticalAlignment="Center"/>
                <StackPanel Spacing="4">
                    <TextBlock Text="Downloads" FontSize="28" FontWeight="SemiBold"/>
                    <TextBlock Text="Manage all download operations"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1" Content="+ New Download"
                    Style="{StaticResource AccentButtonStyle}"
                    VerticalAlignment="Top" Padding="20,8"
                    Click="NewDownloadButton_Click"/>
        </Grid>

        <!-- Filter Chips + Search -->
        <Grid Grid.Row="1" Padding="32,12,32,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Durum Filtreleri -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                <Button Content="All" Tag="All" Click="FilterButton_Click" Padding="16,8"/>
                <Button Content="Active" Tag="Active" Click="FilterButton_Click" Padding="16,8"/>
                <Button Content="Completed" Tag="Completed" Click="FilterButton_Click" Padding="16,8"/>
                <Button Content="Paused" Tag="Paused" Click="FilterButton_Click" Padding="16,8"/>
                <Button Content="Error" Tag="Error" Click="FilterButton_Click" Padding="16,8"/>

                <AutoSuggestBox x:Name="SearchBox" PlaceholderText="Search..."
                                QueryIcon="Find" Width="240" Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                TextChanged="SearchBox_TextChanged"/>
            </StackPanel>

            <!-- Kategori Filtreleri -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <Button Content="All Categories" Tag="CatAll" Click="CategoryFilter_Click" Padding="14,6"/>
                <Button Content="Video" Tag="Video" Click="CategoryFilter_Click" Padding="14,6"/>
                <Button Content="Music" Tag="Music" Click="CategoryFilter_Click" Padding="14,6"/>
                <Button Content="Document" Tag="Document" Click="CategoryFilter_Click" Padding="14,6"/>
                <Button Content="Archive" Tag="Archive" Click="CategoryFilter_Click" Padding="14,6"/>
                <Button Content="Image" Tag="Image" Click="CategoryFilter_Click" Padding="14,6"/>
                <Button Content="Software" Tag="Software" Click="CategoryFilter_Click" Padding="14,6"/>
            </StackPanel>
        </Grid>

        <!-- Downloads List -->
        <ListView Grid.Row="2" x:Name="DownloadsListView"
                  ItemsSource="{Binding FilteredDownloads}"
                  SelectionMode="None" Padding="32,8,32,20"
                  ScrollViewer.HorizontalScrollMode="Disabled"
                  IsItemClickEnabled="True"
                  ItemClick="DownloadsListView_ItemClick">
            <ListView.ItemContainerTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition/>
                </TransitionCollection>
            </ListView.ItemContainerTransitions>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="16,14" Margin="0,0,0,4"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Kategori Ikonu -->
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    VerticalAlignment="Center">
                                <FontIcon Glyph="{Binding CategoryIcon}" FontSize="20"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Dosya Bilgileri -->
                            <Grid Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Dosya Adi -->
                                <TextBlock Grid.Row="0" Text="{Binding FileName}" FontSize="14"
                                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxLines="1"/>

                                <!-- URL -->
                                <TextBlock Grid.Row="1" Text="{Binding DisplayUrl}" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           TextTrimming="CharacterEllipsis" MaxLines="1" Margin="0,2,0,0"/>

                                <!-- Progress Bar -->
                                <Grid Grid.Row="2" Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar Grid.Column="0" Value="{Binding Progress}" Maximum="100"
                                                 Height="4" Margin="0,0,12,0" VerticalAlignment="Center"
                                                 CornerRadius="2"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ProgressText}"
                                               FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </Grid>

                                <!-- Durum Bilgileri -->
                                <Grid Grid.Row="3" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Padding="6,2" CornerRadius="4"
                                            Background="{Binding StatusText, Converter={StaticResource StatusToColorConverter}}" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding StatusText}" FontSize="10"
                                                   Foreground="White" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding SizeText}" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding SpeedText}" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    <TextBlock Grid.Column="3" Text="{Binding EtaText}" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    <TextBlock Grid.Column="4" Text="{Binding ElapsedText}" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                            </Grid>

                            <!-- Aksiyon Butonlari -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                                        Spacing="4">
                                <!-- Duraklat/Devam -->
                                <Button Click="PauseResumeButton_Click" Padding="8">
                                    <ToolTipService.ToolTip><ToolTip Content="Pause/Resume"/></ToolTipService.ToolTip>
                                    <FontIcon Glyph="&#xE769;" FontSize="14"/>
                                </Button>
                                <!-- Dosyayi Ac -->
                                <Button Click="OpenFileButton_Click" Padding="8">
                                    <ToolTipService.ToolTip><ToolTip Content="Open File"/></ToolTipService.ToolTip>
                                    <FontIcon Glyph="&#xE8A7;" FontSize="14"/>
                                </Button>
                                <!-- Klasoru Ac -->
                                <Button Click="OpenFolderButton_Click" Padding="8">
                                    <ToolTipService.ToolTip><ToolTip Content="Open Folder"/></ToolTipService.ToolTip>
                                    <FontIcon Glyph="&#xE838;" FontSize="14"/>
                                </Button>
                                <!-- Iptal -->
                                <Button Click="CancelButton_Click" Padding="8">
                                    <ToolTipService.ToolTip><ToolTip Content="Cancel"/></ToolTipService.ToolTip>
                                    <FontIcon Glyph="&#xE711;" FontSize="14"/>
                                </Button>
                                <!-- Kaldir -->
                                <Button Click="RemoveButton_Click" Padding="8">
                                    <ToolTipService.ToolTip><ToolTip Content="Remove"/></ToolTipService.ToolTip>
                                    <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                </Button>
                                <!-- DigerSecenekler -->
                                <Button x:Name="MoreOptionsButton" Click="MoreOptionsButton_Click" Padding="8">
                                    <ToolTipService.ToolTip><ToolTip Content="More Options"/></ToolTipService.ToolTip>
                                    <FontIcon Glyph="&#xE712;" FontSize="14"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty State -->
        <Border Grid.Row="2" x:Name="EmptyStatePanel" Visibility="Visible"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                CornerRadius="12" Margin="32,8,32,20">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                <FontIcon Glyph="&#xE896;" FontSize="56" HorizontalAlignment="Center"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                <TextBlock Text="No downloads yet" FontSize="18" HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="To add a new download, click the button or paste a URL"
                           FontSize="12" HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
