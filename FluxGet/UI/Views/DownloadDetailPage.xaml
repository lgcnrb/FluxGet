<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FluxGet.UI.Views.DownloadDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24">
        <StackPanel MaxWidth="600" HorizontalAlignment="Center">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>
            
            <!-- Header -->
            <StackPanel Margin="0,0,0,24">
                <TextBlock 
                    x:Name="TitleText"
                    FontSize="28" 
                    FontWeight="Bold"
                    TextTrimming="CharacterEllipsis"/>
                <TextBlock 
                    x:Name="UrlText"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextTrimming="CharacterEllipsis"
                    Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Progress -->
            <Border Padding="20" Margin="0,0,0,16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12">
                <StackPanel>
                    <ProgressBar 
                        x:Name="ProgressBar"
                        Maximum="100"
                        Height="8"/>
                    
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock 
                            x:Name="ProgressText"
                            FontSize="24"
                            FontWeight="Bold"
                            HorizontalAlignment="Left"/>
                        
                        <StackPanel 
                            Grid.Column="1" 
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">
                            <TextBlock 
                                x:Name="DownloadedText"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Margin="0,0,8,0"/>
                            <TextBlock 
                                Text="/"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock 
                                x:Name="TotalSizeText"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Margin="8,0,0,0"/>
                        </StackPanel>
                        
                        <TextBlock 
                            Grid.Column="2"
                            x:Name="SpeedText"
                            FontSize="14"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Status -->
            <Border Padding="16" Margin="0,0,0,16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <TextBlock Text="Status" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock 
                            x:Name="StatusText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Category" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock 
                            x:Name="CategoryText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Details -->
            <Border Padding="16" Margin="0,0,0,16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="Details" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    
                    <Grid RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Text="File Name" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" x:Name="FileNameText" TextWrapping="Wrap"/>
                        
                        <TextBlock Grid.Row="1" Text="Save Path" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="FilePathText" TextWrapping="Wrap"/>
                        
                        <TextBlock Grid.Row="2" Text="Started" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="CreatedText"/>
                        
                        <TextBlock Grid.Row="3" Text="Completed" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="CompletedText"/>
                        
                        <TextBlock Grid.Row="4" Text="Est. Time" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="EtaText"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <Border Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button 
                        x:Name="StartButton"
                        Content="Start"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="StartButton_Click"
                        Margin="0,0,8,0"/>
                    
                    <Button 
                        x:Name="PauseButton"
                        Content="Pause"
                        Click="PauseButton_Click"
                        Margin="0,0,8,0"/>
                    
                    <Button 
                        x:Name="ResumeButton"
                        Content="Resume"
                        Click="ResumeButton_Click"
                        Margin="0,0,8,0"/>
                    
                    <Button 
                        x:Name="CancelButton"
                        Content="Cancel"
                        Click="CancelButton_Click"
                        Margin="0,0,8,0"/>
                    
                    <Button 
                        x:Name="OpenFileButton"
                        Content="Open File"
                        Click="OpenFileButton_Click"
                        Margin="0,0,8,0"/>
                    
                    <Button 
                        x:Name="OpenFolderButton"
                        Content="Open Folder"
                        Click="OpenFolderButton_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
