<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FluxGet.UI.Views.QueuePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Padding="32,20,32,0" Margin="0,0,0,16" Orientation="Horizontal" Spacing="10">
            <FontIcon Glyph="&#xE8A7;" FontSize="28" VerticalAlignment="Center"/>
            <StackPanel Spacing="4">
                <TextBlock 
                    Text="Indirme Kuyrugu" 
                    FontSize="28" 
                    FontWeight="SemiBold"/>
                <TextBlock 
                    x:Name="QueueStatusText"
                    Text="0 kuyrukta, 0 aktif"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </StackPanel>

        <!-- Settings -->
        <Border Grid.Row="1" Padding="32,0,32,0" Margin="0,0,0,16">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="10" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock 
                            Text="Maks Es Zamanli:" 
                            FontWeight="SemiBold"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0"/>
                        <NumberBox 
                            x:Name="MaxConcurrentBox"
                            Minimum="1"
                            Maximum="20"
                            Value="3"
                            Width="80"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Uygula" Click="ApplyButton_Click"
                                Style="{StaticResource AccentButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Kuyrugu Durdur" Click="PauseQueueButton_Click" Margin="0,0,8,0"/>
                        <Button Content="Kuyrugu Devam Ettir" Click="ResumeQueueButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- Table Header -->
        <Grid Grid.Row="2" Padding="32,0,32,0">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                    CornerRadius="8,8,0,0" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="#" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="Sira" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Grid.Column="2" Text="Dosya Adi" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Grid.Column="3" Text="Boyut" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Grid.Column="4" Text="Oncelik" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Grid.Column="5" Text="Durum" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Grid.Column="6" Text="Islemler" FontWeight="SemiBold" FontSize="12"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Queue List -->
        <ListView 
            Grid.Row="3"
            x:Name="QueueListView"
            ItemsSource="{Binding QueueItems}"
            Padding="32,0,32,20"
            ScrollViewer.HorizontalScrollMode="Disabled"
            SelectionMode="None">
            <ListView.ItemContainerTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition/>
                </TransitionCollection>
            </ListView.ItemContainerTransitions>
            
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="16,10" 
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        
                        <FontIcon Grid.Column="0" Glyph="{Binding CategoryIcon}" FontSize="14"
                                  VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        
                        <TextBlock Grid.Column="1" Text="{Binding QueueOrder}" VerticalAlignment="Center" 
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock 
                                Text="{Binding FileName}"
                                FontWeight="SemiBold"
                                TextTrimming="CharacterEllipsis"/>
                            <TextBlock 
                                Text="{Binding DisplayUrl}"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                TextTrimming="CharacterEllipsis"
                                MaxLines="1"
                                Margin="0,2,0,0"/>
                        </StackPanel>
                        
                        <TextBlock Grid.Column="3" Text="{Binding SizeText}" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        
                        <TextBlock Grid.Column="4" Text="{Binding PriorityText}" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        
                        <TextBlock Grid.Column="5" Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        
                        <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Click="MoveUpButton_Click" Padding="6" Margin="0,0,4,0"
                                    ToolTipService.ToolTip="Yukari Tas">
                                <FontIcon Glyph="&#xE70E;" FontSize="12"/>
                            </Button>
                            <Button Click="MoveDownButton_Click" Padding="6" Margin="0,0,4,0"
                                    ToolTipService.ToolTip="Asagi Tas">
                                <FontIcon Glyph="&#xE70D;" FontSize="12"/>
                            </Button>
                            <Button Click="PriorityUpButton_Click" Padding="6" Margin="0,0,4,0"
                                    ToolTipService.ToolTip="Onceligi Artir">
                                <FontIcon Glyph="&#xE73A;" FontSize="12"/>
                            </Button>
                            <Button Click="PriorityDownButton_Click" Padding="6" Margin="0,0,4,0"
                                    ToolTipService.ToolTip="Onceligi Azalt">
                                <FontIcon Glyph="&#xE73B;" FontSize="12"/>
                            </Button>
                            <Button Click="RemoveButton_Click" Padding="6"
                                    ToolTipService.ToolTip="Kuyruktan Cikar">
                                <FontIcon Glyph="&#xE711;" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty State -->
        <StackPanel 
            x:Name="EmptyStatePanel"
            Grid.Row="3"
            VerticalAlignment="Center"
            HorizontalAlignment="Center">
            <FontIcon Glyph="&#xE896;" FontSize="48" HorizontalAlignment="Center"
                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            <TextBlock Text="Kuyruk bos" FontSize="18" HorizontalAlignment="Center"
                       Margin="0,12,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Text="Indirmeleri kuyruga eklemek icin 'Yeni Indirme' kullanin"
                       FontSize="13" HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Footer Actions -->
        <StackPanel 
            Grid.Row="4"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Padding="32,16,32,20">
            <Button 
                Content="Kuyrugu Temizle"
                Click="ClearQueueButton_Click"
                Margin="0,0,8,0"/>
            <Button 
                Content="Tumunu Indirmeyi Baslat"
                Style="{StaticResource AccentButtonStyle}"
                Click="StartAllButton_Click"/>
        </StackPanel>
    </Grid>
</Page>
