<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FluxGet.UI.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" HorizontalAlignment="Stretch">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                <FontIcon Glyph="&#xE946;" FontSize="28" VerticalAlignment="Center"/>
                <StackPanel Spacing="4">
                    <TextBlock Text="Hakkinda" FontSize="28" FontWeight="SemiBold"/>
                    <TextBlock Text="FluxGet hakkinda bilgiler"
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- App Identity -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="24,20">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="72" Height="72" CornerRadius="16"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            VerticalAlignment="Center">
                        <Image Source="ms-appx:///Assets/FluxGet.png" Width="72" Height="72" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Stretch="Uniform"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="FluxGet" FontSize="24" FontWeight="Bold"/>
                        <TextBlock x:Name="VersionText" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Gelismis indirme yoneticisi. Hizli, guvenilir, akillica."
                                   FontSize="13" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- System Info -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                        <FontIcon Glyph="&#xE770;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Sistem Bilgisi" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Platform" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="PlatformText" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Runtime" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="RuntimeText" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="WinUI" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="WinUIText" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="SQLite" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="EF Core 9.0 (SQLite)" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="MVVM" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="CommunityToolkit.Mvvm 8.4" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Indirme Motoru" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Parallel Chunk / HttpClient" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="YouTube Entegrasyonu" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="yt-dlp + ffmpeg" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tarayici Eklentisi" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Chrome Manifest v3" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Features -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                        <FontIcon Glyph="&#xE945;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Ozellikler" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="  &#x2022;  Cok baglantili paralel indirme (chunk destekli)" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Duraklat / Devam / Yeniden Dene" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Kuresel ve indirme bazli hiz limiti" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Oncelikli kuyruk sistemi" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Otomatik kategori tespiti" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Dosya hash dogrulama (SHA256/SHA1/MD5)" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  YouTube video/MP3 indirme (otomatik birlestirme)" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Cerez bazli YouTube oturum destegi" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Tarayici eklentisi entegrasyonu" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Pano URL algilama" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Surukle-birak ile indirme" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  SQLite veritabani ile kalici depolama" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Links -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                        <FontIcon Glyph="&#xE71B;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Lisans" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="MIT Lisansi - Ucretsiz ve acik kaynak"
                               FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="Copyright (c) 2026 FluxGet"
                               FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Thanks -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <FontIcon Glyph="&#xE8D6;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Teknolojiler" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="C# 12, .NET 8, Windows App SDK 1.6, WinUI 3, Entity Framework Core, System.Reactive, CommunityToolkit.Mvvm, yt-dlp, ffmpeg"
                               FontSize="12" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Credits -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <FontIcon Glyph="&#xE716;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Ucuncu Taraf Araclar" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="yt-dlp - YouTube video indirme motoru (Unlicense)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="ffmpeg - Ses/goruntu donusturme araci (LGPL/GPL)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
