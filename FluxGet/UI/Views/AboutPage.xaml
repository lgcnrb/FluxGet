<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FluxGet.UI.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" HorizontalAlignment="Stretch">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                <FontIcon Glyph="&#xE946;" FontSize="28" VerticalAlignment="Center"/>
                <StackPanel Spacing="4">
                    <TextBlock Text="About" FontSize="28" FontWeight="SemiBold"/>
                    <TextBlock Text="Information about FluxGet"
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- App Identity -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="24,20">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="72" Height="72" CornerRadius="16"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            VerticalAlignment="Center">
                        <Image Source="ms-appx:///Assets/FluxGet.png" Width="72" Height="72" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Stretch="Uniform"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="FluxGet" FontSize="24" FontWeight="Bold"/>
                        <TextBlock x:Name="VersionText" FontSize="14"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Advanced download manager. Fast, reliable, smart."
                                   FontSize="13" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- System Info -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                        <FontIcon Glyph="&#xE770;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="System Information" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Platform" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="PlatformText" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Runtime" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="RuntimeText" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="WinUI" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="WinUIText" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="SQLite" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="EF Core 9.0 (SQLite)" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="MVVM" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="CommunityToolkit.Mvvm 8.4" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Download Engine" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Parallel Chunk / HttpClient" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="YouTube Integration" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="yt-dlp + ffmpeg" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Height="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Browser Extension" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Chrome Manifest v3" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Features -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                        <FontIcon Glyph="&#xE945;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Features" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="  &#x2022;  Multi-connection parallel download (chunk supported)" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Pause / Resume / Retry" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Global and per-download speed limit" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Priority queue system" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Automatic category detection" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  File hash verification (SHA256/SHA1/MD5)" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  YouTube video/MP3 download (auto-merge)" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Cookie-based YouTube session support" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Browser extension integration" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Clipboard URL detection" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Drag and drop download" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="  &#x2022;  Persistent storage with SQLite database" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Links -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                        <FontIcon Glyph="&#xE71B;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="License" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="MIT License - Free and open source"
                               FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="Copyright (c) 2026 FluxGet"
                               FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Thanks -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <FontIcon Glyph="&#xE8D6;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Technologies" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="C# 12, .NET 8, Windows App SDK 1.6, WinUI 3, Entity Framework Core, System.Reactive, CommunityToolkit.Mvvm, yt-dlp, ffmpeg"
                               FontSize="12" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Credits -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <FontIcon Glyph="&#xE716;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Third Party Tools" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="yt-dlp - YouTube video download engine (Unlicense)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="ffmpeg - Audio/video conversion tool (LGPL/GPL)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
