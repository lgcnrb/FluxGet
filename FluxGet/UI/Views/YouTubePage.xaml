<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FluxGet.UI.Views.YouTubePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Padding="24,16" ColumnSpacing="20" RowSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="10" Margin="0,0,0,20">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>
            <FontIcon Glyph="&#xE714;" FontSize="28" Foreground="#FF0000" VerticalAlignment="Center"/>
            <StackPanel Spacing="4">
                <TextBlock Text="YouTube Downloader" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="Download YouTube videos as MP4 or MP3"
                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </StackPanel>

        <!-- LEFT COLUMN: Controls -->
        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="16" VerticalAlignment="Top">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <!-- URL Input Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,16">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE774;" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="YouTube URL" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="UrlBox" PlaceholderText="https://youtube.com/watch?v=..."
                                 Text="{x:Bind VM.Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center"
                                 KeyDown="UrlBox_KeyDown"/>

                        <Button Grid.Column="1" Content="Fetch Info"
                                Style="{StaticResource AccentButtonStyle}" Padding="20,8"
                                Command="{x:Bind VM.FetchInfoCommand}"
                                IsEnabled="{x:Bind VM.IsFetching, Mode=OneWay, Converter={StaticResource InvertBoolConverter}}"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Status -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                Visibility="{x:Bind VM.IsFetching, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressRing Width="16" Height="16"
                                      IsActive="{x:Bind VM.IsFetching, Mode=OneWay}"/>
                        <TextBlock FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="Fetching video info..."/>
                    </StackPanel>

                    <!-- Error -->
                    <InfoBar Severity="Error" IsOpen="{x:Bind VM.HasError, Mode=TwoWay}" IsClosable="True"
                             Title="{x:Bind VM.ErrorMessage, Mode=OneWay}"
                             Visibility="{x:Bind VM.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                             Margin="0,4,0,0">
                        <InfoBar.ActionButton>
                            <Button Content="Retry" Command="{x:Bind VM.FetchInfoCommand}"
                                    Style="{StaticResource AccentButtonStyle}" Padding="12,4" FontSize="12"/>
                        </InfoBar.ActionButton>
                    </InfoBar>
                </StackPanel>
            </Border>

            <!-- Tools Status -->
            <InfoBar Severity="Warning" IsOpen="True" IsClosable="False"
                     Title="yt-dlp not installed"
                     Visibility="{x:Bind VM.ShowToolsWarning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="yt-dlp is required for YouTube downloads." VerticalAlignment="Center"
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Button Content="Go to Settings" Click="GoToSettingsButton_Click"
                            Style="{StaticResource AccentButtonStyle}" Padding="16,4" FontSize="12"/>
                </StackPanel>
            </InfoBar>

            <!-- Video Info + Format Selection Card -->
            <Border Visibility="{x:Bind VM.VideoInfo, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,16">
                <StackPanel Spacing="12">
                    <TextBlock Text="{x:Bind VM.VideoTitle, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Padding="8,4" CornerRadius="6"
                                Background="{ThemeResource LayerFillColorDefaultBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE77B;" FontSize="12" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind VM.VideoUploader, Mode=OneWay}" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Padding="8,4" CornerRadius="6"
                                Background="{ThemeResource LayerFillColorDefaultBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE767;" FontSize="12" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind VM.VideoDuration, Mode=OneWay}" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                    <!-- Format Selection -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Download Format" FontSize="14" FontWeight="SemiBold"/>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="Mp4Card" Grid.Column="0" Padding="16,16" CornerRadius="12"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="2"
                                    PointerPressed="Mp4Card_PointerPressed">
                                <StackPanel Spacing="6">
                                    <Border Width="40" Height="40" CornerRadius="10" Background="#1a3a5c">
                                        <FontIcon Glyph="&#xE714;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Foreground="#60cdff"/>
                                    </Border>
                                    <TextBlock Text="MP4" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="Video + Audio" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind VM.Mp4SizeText, Mode=OneWay}" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="Mp3Card" Grid.Column="1" Padding="16,16" CornerRadius="12"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="2"
                                    PointerPressed="Mp3Card_PointerPressed">
                                <StackPanel Spacing="6">
                                    <Border Width="40" Height="40" CornerRadius="10" Background="#1a3c1a">
                                        <FontIcon Glyph="&#xE8D6;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Foreground="#4cc764"/>
                                    </Border>
                                    <TextBlock Text="MP3" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="Audio Only" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind VM.Mp3SizeText, Mode=OneWay}" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <StackPanel Visibility="{x:Bind VM.IsMp4Mode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Spacing="6" Margin="0,4,0,0">
                            <TextBlock Text="Resolution" FontSize="13" FontWeight="SemiBold"/>
                            <ComboBox x:Name="ResolutionComboBox" MinWidth="300" HorizontalAlignment="Left"
                                      ItemsSource="{x:Bind VM.Resolutions}"
                                      SelectedIndex="{x:Bind VM.SelectedResolutionIndex, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayText"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                    <!-- Save Path -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Save Location" FontSize="13" FontWeight="SemiBold"/>
                        <Border Padding="12,8" CornerRadius="8"
                                Background="{ThemeResource LayerFillColorDefaultBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE8B8;" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind VM.SavePath, Mode=OneWay}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" Grid.Column="1"/>
                                <Button Grid.Column="2" Content="Change" Click="ChangePathButton_Click" Margin="12,0,0,0"
                                        Padding="12,4" FontSize="12"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Button Content="Start Download"
                            Style="{StaticResource AccentButtonStyle}" Padding="24,12"
                            HorizontalAlignment="Stretch" FontSize="14"
                            Command="{x:Bind VM.DownloadCommand}"
                            IsEnabled="{x:Bind VM.IsDownloading, Mode=OneWay, Converter={StaticResource InvertBoolConverter}}"
                            Visibility="{x:Bind VM.VideoInfo, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <!-- Download Progress -->
            <Border Visibility="{x:Bind VM.IsDownloading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,16">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE896;" FontSize="14" VerticalAlignment="Center" Foreground="#60cdff"/>
                        <TextBlock Text="Download Status" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ProgressBar Maximum="100" Height="8" CornerRadius="4"
                                 Foreground="#60cdff"
                                 Value="{x:Bind VM.DownloadProgress, Mode=OneWay}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind VM.DownloadProgressText, Mode=OneWay}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#60cdff" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{x:Bind VM.DownloadStatusText, Mode=OneWay}"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- RIGHT COLUMN: Video Preview -->
        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="16" VerticalAlignment="Top" MinWidth="340" MaxWidth="420">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <Border Visibility="{x:Bind VM.VideoInfo, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="12">
                <StackPanel Spacing="12">
                    <Border CornerRadius="8" MaxHeight="240">
                        <Image Stretch="UniformToFill" MaxHeight="240"
                               Source="{x:Bind VM.VideoThumbnailUrl, Mode=OneWay}"/>
                    </Border>

                    <StackPanel Spacing="8">
                        <TextBlock Text="{x:Bind VM.VideoTitle, Mode=OneWay}" FontSize="14" FontWeight="SemiBold"
                                   TextWrapping="Wrap" MaxLines="3"/>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE77B;" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind VM.VideoUploader, Mode=OneWay}" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE767;" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind VM.VideoDuration, Mode=OneWay}" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Selected Download" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Padding="8,4" CornerRadius="6"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                                <TextBlock Text="{x:Bind VM.SelectedFormatText, Mode=OneWay}" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                            <Border Padding="8,4" CornerRadius="6"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                                <TextBlock Text="{x:Bind VM.SelectedSizeText, Mode=OneWay}" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Page>
