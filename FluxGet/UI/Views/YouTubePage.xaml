<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FluxGet.UI.Views.YouTubePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Padding="24,16" ColumnSpacing="20" RowSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="10" Margin="0,0,0,20">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>
            <FontIcon Glyph="&#xE714;" FontSize="28" Foreground="#FF0000" VerticalAlignment="Center"/>
            <StackPanel Spacing="4">
                <TextBlock Text="YouTube Indirici" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="YouTube videolarini MP4 veya MP3 olarak indirin"
                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </StackPanel>

        <!-- SOL KOLON: Kontroller -->
        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="16" VerticalAlignment="Top">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <!-- URL Giris Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,16">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE774;" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="YouTube URL" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="UrlBox" PlaceholderText="https://youtube.com/watch?v=... veya youtu.be/..."
                                 VerticalAlignment="Center"
                                 KeyDown="UrlBox_KeyDown"/>

                        <Button Grid.Column="1" x:Name="FetchInfoButton" Content="Bilgi Getir"
                                Style="{StaticResource AccentButtonStyle}" Padding="20,8"
                                Click="FetchInfoButton_Click" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Durum -->
                    <StackPanel x:Name="StatusPanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                        <ProgressRing x:Name="StatusRing" Width="16" Height="16"/>
                        <TextBlock x:Name="StatusText" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Hata -->
                    <InfoBar x:Name="ErrorInfoBar" Severity="Error" IsOpen="True" IsClosable="True"
                             Visibility="Collapsed" Margin="0,4,0,0">
                        <InfoBar.ActionButton>
                            <Button x:Name="RetryDownloadButton" Content="Yeniden Dene" Click="RetryDownloadButton_Click"
                                    Style="{StaticResource AccentButtonStyle}" Padding="12,4" FontSize="12"/>
                        </InfoBar.ActionButton>
                    </InfoBar>
                </StackPanel>
            </Border>

            <!-- Araclar Durumu -->
            <InfoBar x:Name="ToolsInfoBar" Severity="Warning" IsOpen="True" IsClosable="False"
                     Title="yt-dlp yuklu degil"
                     Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="YouTube indirmeleri icin yt-dlp gerekli." VerticalAlignment="Center"
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Button x:Name="GoToSettingsButton" Content="Ayarlara Git" Click="GoToSettingsButton_Click"
                            Style="{StaticResource AccentButtonStyle}" Padding="16,4" FontSize="12"/>
                </StackPanel>
            </InfoBar>

            <!-- Video Bilgisi + Format Secimi Card -->
            <Border x:Name="VideoInfoBorder" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,16">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="VideoTitleText" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Padding="8,4" CornerRadius="6"
                                Background="{ThemeResource LayerFillColorDefaultBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE77B;" FontSize="12" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="VideoUploaderText" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Padding="8,4" CornerRadius="6"
                                Background="{ThemeResource LayerFillColorDefaultBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE767;" FontSize="12" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="VideoDurationText" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                    <!-- Format Secimi -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Indirme Formati" FontSize="14" FontWeight="SemiBold"/>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="Mp4Card" Grid.Column="0" Padding="16,16" CornerRadius="12"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="2"
                                    PointerPressed="Mp4Card_PointerPressed">
                                <StackPanel Spacing="6">
                                    <Border Width="40" Height="40" CornerRadius="10" Background="#1a3a5c">
                                        <FontIcon Glyph="&#xE714;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Foreground="#60cdff"/>
                                    </Border>
                                    <TextBlock Text="MP4" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="Video + Ses" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="Mp4SizeText" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="Mp3Card" Grid.Column="1" Padding="16,16" CornerRadius="12"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="2"
                                    PointerPressed="Mp3Card_PointerPressed">
                                <StackPanel Spacing="6">
                                    <Border Width="40" Height="40" CornerRadius="10" Background="#1a3c1a">
                                        <FontIcon Glyph="&#xE8D6;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Foreground="#4cc764"/>
                                    </Border>
                                    <TextBlock Text="MP3" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="Sadece Ses" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="Mp3SizeText" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <StackPanel x:Name="ResolutionPanel" Visibility="Collapsed" Spacing="6" Margin="0,4,0,0">
                            <TextBlock Text="Cozunurluk" FontSize="13" FontWeight="SemiBold"/>
                            <ComboBox x:Name="ResolutionComboBox" MinWidth="300" HorizontalAlignment="Left"
                                      SelectionChanged="ResolutionComboBox_SelectionChanged"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                    <!-- Kaydet Yolu -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Kaydet Konumu" FontSize="13" FontWeight="SemiBold"/>
                        <Border Padding="12,8" CornerRadius="8"
                                Background="{ThemeResource LayerFillColorDefaultBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE8B8;" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="SavePathText" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" Grid.Column="1"/>
                                <Button Grid.Column="2" Content="Degistir" Click="ChangePathButton_Click" Margin="12,0,0,0"
                                        Padding="12,4" FontSize="12"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Button x:Name="DownloadButton" Content="Indirmeyi Baslat"
                            Style="{StaticResource AccentButtonStyle}" Padding="24,12"
                            HorizontalAlignment="Stretch" FontSize="14"
                            Click="DownloadButton_Click" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- Indirme Ilerlemesi -->
            <Border x:Name="ProgressBorder" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,16">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE896;" FontSize="14" VerticalAlignment="Center" Foreground="#60cdff"/>
                        <TextBlock Text="Indirme Durumu" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ProgressBar x:Name="DownloadProgressBar" Maximum="100" Height="8" CornerRadius="4"
                                 Foreground="#60cdff"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DownloadPercentText" Text="%0" FontSize="16" FontWeight="Bold"
                                   Foreground="#60cdff" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="DownloadStatusText" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- SAG KOLON: Video Onizleme -->
        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="16" VerticalAlignment="Top" MinWidth="340" MaxWidth="420">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <Border x:Name="VideoPreviewBorder" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="12">
                <StackPanel Spacing="12">
                    <Border CornerRadius="8" MaxHeight="240">
                        <Image x:Name="ThumbnailImage" Stretch="UniformToFill" MaxHeight="240"/>
                    </Border>

                    <StackPanel Spacing="8">
                        <TextBlock x:Name="PreviewTitleText" FontSize="14" FontWeight="SemiBold"
                                   TextWrapping="Wrap" MaxLines="3"/>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE77B;" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="PreviewUploaderText" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE767;" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="PreviewDurationText" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Secilen Indirme" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border x:Name="SelectedFormatBadge" Padding="8,4" CornerRadius="6"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                                <TextBlock x:Name="SelectedFormatText" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                            <Border x:Name="SelectedSizeBadge" Padding="8,4" CornerRadius="6"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                                <TextBlock x:Name="SelectedSizeText" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Page>
