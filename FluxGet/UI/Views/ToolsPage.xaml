<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FluxGet.UI.Views.ToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="32,20,32,20" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition/>
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                <FontIcon Glyph="&#xE74E;" FontSize="28" VerticalAlignment="Center"/>
                <StackPanel Spacing="4">
                    <TextBlock Text="Tools" FontSize="28" FontWeight="SemiBold"/>
                    <TextBlock Text="Manage YouTube download and conversion tools"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- yt-dlp -->
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                    <FontIcon Glyph="&#xE714;" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="yt-dlp" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="YouTube Video Download Engine" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Download support for YouTube, Vimeo and other video sites" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" x:Name="YtDlpStatusText" Text="Checking..."
                                       FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                        <TextBlock x:Name="YtDlpPathText" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="YtDlpVersionText" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   Visibility="Collapsed"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
<Button x:Name="YtDlpSelectButton" Content="Select File" Click="YtDlpSelectButton_Click"
                                     Padding="12,6"/>
                            <Button Content="Download (GitHub)" Click="YtDlpDownloadButton_Click"
                                     Padding="12,6"/>
                            <Button x:Name="YtDlpCheckUpdateButton" Content="Check for Updates?"
                                    Click="YtDlpCheckUpdateButton_Click" Padding="12,6"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ffmpeg -->
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,8">
                    <FontIcon Glyph="&#xE8D6;" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="ffmpeg" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Audio Conversion Tool" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Create MP3 audio files from YouTube videos" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" x:Name="FfmpegStatusText" Text="Checking..."
                                       FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                        <TextBlock x:Name="FfmpegPathText" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="FfmpegVersionText" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   Visibility="Collapsed"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
<Button x:Name="FfmpegSelectButton" Content="Select File" Click="FfmpegSelectButton_Click"
                                     Padding="12,6"/>
                            <Button Content="Download (GitHub)" Click="FfmpegDownloadButton_Click"
                                     Padding="12,6"/>
                            <Button x:Name="FfmpegCheckUpdateButton" Content="Check for Updates?"
                                    Click="FfmpegCheckUpdateButton_Click" Padding="12,6"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Aracl Klasoru -->
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,8">
                    <FontIcon Glyph="&#xE8B7;" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="Tools Folder" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
<TextBlock Text="Tool Files Location" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Folder where yt-dlp and ffmpeg files are stored" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Open Folder" Click="OpenToolsFolderButton_Click"
                                Padding="12,4" Margin="12,0,0,0"/>
                    </Grid>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
